---
const { user } = Astro.locals;
---

<div class="flex items-center gap-4 text-neutral-500 dark:text-neutral-400">
  {
    user ? (
      <a
        href="/profile"
        class="hover:underline leading-none hover:text-neutral-800 dark:hover:text-neutral-300"
      >
        Perfil
      </a>
    ) : (
      <a
        href="/auth/login"
        class="hover:underline leading-none hover:text-neutral-800 dark:hover:text-neutral-300"
      >
        Iniciar sesión
      </a>
    )
  }
</div>
