---
import Layout from "../../layouts/Layout.astro";

import "@fontsource/kalam";

const icus = [
  {
    name: "Jose Maria Tarima C.",
    cargo: "Delegado Titular 1",
    number: "79831485",
    image: "/plancha/001.png",
  },
  {
    name: "Jhonathan Camacho",
    cargo: "Delegado Alterno 1",
    number: "70966931",
    image: "/plancha/003.png",
  },
  {
    name: "Esteban Veizaga",
    cargo: "Delegado Titular 2",
    number: "75611300",
    image: "/plancha/002.png",
  },
  {
    name: "Sebastian Max S.",
    cargo: "Delegado Alterno 2",
    number: "63476921",
    image: "/plancha/004.png",
  },
];
---

<Layout title="Planchas">
  <p
    data-aos="fade-down"
    data-aos-delay="50"
    class="font-bold text-neutral-600 dark:text-neutral-300 text-center leading-none mt-10"
  >
    Lista de
  </p>
  <h2
    data-aos="fade-up"
    data-aos-delay="50"
    class="text-2xl sm:text-3xl md:text-4xl uppercase font-black text-neutral-800 dark:text-neutral-50 text-center max-w-2xl mx-auto"
  >
    Delegados Ilustre Consejo Universitario
  </h2>
  <p
    data-aos="fade-up"
    data-aos-delay="100"
    class="text-center font-bold text-primary mb-5"
  >
    #M.G.S.-I.C.U.
  </p>

  <section
    class="w-[80dvw] mx-auto max-w-2xl flex flex-col justify-start gap-16 pb-20"
  >
    <!-- <h2 data-aos="fade-up" data-aos-delay="50" class="text-center text-xl font-medium text-neutral-800 dark:text-neutral-200 uppercase">En construcción</h2> -->

    {
      icus.map((plancha) => (
        <article class="flex flex-col md:flex-row gap-4 items-center justify-center mx-auto md:ml-0">
          <img
            src={plancha.image}
            alt={plancha.name}
            loading="lazy"
            class="w-52 aspect-auto"
          />
          <div class="space-y-4 text-center md:text-left dark:text-neutral-50">
            <h2 class="text-3xl font-bold">{plancha.name}</h2>
            <p class="text-xl font-medium font-kalam">{plancha.cargo}</p>

            <a
              target="_blank"
              href={
                "https://api.whatsapp.com/send?phone=591" +
                plancha.number +
                "&text=Hola%2C%20te%20escribo%20desde%20la%20p%C3%A1gina%20de%20Megaloblastos.%20Necesito%20tu%20ayuda"
              }
              rel="noopener noreferrer"
              class="inline-block py-2 px-8 bg-green-500 text-neutral-50 rounded-lg"
            >
              <p class="leading-none">Contactar</p>
            </a>
          </div>
        </article>
      ))
    }
  </section>
</Layout>
