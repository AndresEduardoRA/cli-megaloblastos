---
import Layout from "@/layouts/Layout.astro";
import RentalModal from "@/components/servicios/RentalModal.vue";
import { supabase } from "@/utils/supabase";
import BtnBack from "@/components/UI/BtnBack.astro";

const user = Astro.locals.user;
let userProfile = null;

if (user) {
  const { data } = await supabase
    .from("profiles")
    .select("*")
    .eq("id", user.id)
    .single();

  if (data) {
    // @ts-ignore
    userProfile = { ...data, email: user.email };
  }
}
---

<Layout title="Alquiler de Batas - Megaloblastos">
  <section class="max-w-7xl mx-auto px-4 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-neutral-900 dark:text-white mb-4">
        Servicio de Alquiler de Batas
      </h1>
      <p class="text-lg text-neutral-600 dark:text-neutral-400">
        Selecciona el tipo de bata que necesitas.
      </p>
      <BtnBack />
    </div>

    {
      !userProfile ? (
        <div class="max-w-96 mx-auto bg-amber-50 dark:bg-amber-900/30 border border-amber-200 dark:border-amber-700 rounded-lg p-6 text-center">
          <i class="ri-lock-2-line text-4xl text-amber-600 mb-4 inline-block" />
          <h2 class="text-xl font-bold text-neutral-800 dark:text-neutral-100 mb-2">
            Inicia sesión para alquilar
          </h2>
          <p class="text-neutral-600 dark:text-neutral-300 mb-6">
            Necesitas tener una cuenta registrada y verificada para acceder al
            servicio de alquiler.
          </p>
          <div class="flex gap-4 justify-center">
            <a
              href="/auth/login"
              class="px-6 py-2 bg-amber-600 text-white rounded-lg hover:bg-amber-700 transition"
            >
              Iniciar Sesión
            </a>
            <a
              href="/auth/register"
              class="px-6 py-2 border border-amber-600 text-amber-600 dark:text-amber-400 rounded-lg hover:bg-amber-50 dark:hover:bg-amber-900/50 transition"
            >
              Registrarse
            </a>
          </div>
        </div>
      ) : (
        <RentalModal client:load user={userProfile} />
      )
    }
  </section>
</Layout>
