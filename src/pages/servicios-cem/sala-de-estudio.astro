---
import Layout from "@/layouts/Layout.astro";
import StudyRoomBooking from "@/components/servicios/StudyRoomBooking.vue";
import { supabase } from "@/utils/supabase";
import BtnBack from "@/components/UI/BtnBack.astro";

const user = Astro.locals.user;
let userProfile = null;

if (user) {
  const { data } = await supabase
    .from("profiles")
    .select("id, first_name, last_name, student_code")
    .eq("id", user.id)
    .single();

  if (data) {
    userProfile = data;
  }
}
---

<Layout title="Sala de Estudio - Megaloblastos">
  <section class="max-w-7xl mx-auto px-4 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-neutral-900 dark:text-white mb-4">
        Reserva de Sala de Estudio
      </h1>
      <p class="text-lg text-neutral-600 dark:text-neutral-400">
        Horarios disponibles para el día de hoy.
      </p>
      <BtnBack />
    </div>

    {
      !userProfile ? (
        <div class="max-w-96 mx-auto bg-amber-50 dark:bg-amber-900/30 border border-amber-200 dark:border-amber-700 rounded-lg p-6 text-center">
          <i class="ri-calendar-check-line text-4xl text-amber-600 mb-4 inline-block" />
          <h2 class="text-xl font-bold text-neutral-800 dark:text-neutral-100 mb-2">
            Inicia sesión para reservar
          </h2>
          <div class="flex gap-4 justify-center mt-6">
            <a
              href="/auth/login"
              class="px-6 py-2 bg-amber-600 text-white rounded-lg hover:bg-amber-700 transition"
            >
              Iniciar Sesión
            </a>
          </div>
        </div>
      ) : (
        <StudyRoomBooking client:visible user={userProfile} />
      )
    }
  </section>
</Layout>
