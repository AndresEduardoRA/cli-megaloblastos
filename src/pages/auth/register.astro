---
import Layout from "../../layouts/Layout.astro";
import { supabase } from "../../utils/supabase";

let errorMessage = "";
let successMessage = "";

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get("email")?.toString();
    const password = formData.get("password")?.toString();
    const confirmPassword = formData.get("confirmPassword")?.toString();
    const firstName = formData.get("firstName")?.toString();
    const lastName = formData.get("lastName")?.toString();
    const studentCode = formData.get("studentCode")?.toString();
    const phone = formData.get("phone")?.toString();
    const carnetNumber = formData.get("carnetNumber")?.toString();
    // const avatarFile = formData.get("avatar") as File;

    if (
      !email ||
      !password ||
      !firstName ||
      !lastName ||
      !studentCode ||
      !phone ||
      !carnetNumber
      // !avatarFile
    ) {
      throw new Error("Todos los campos son obligatorios.");
    }

    if (password !== confirmPassword) {
      throw new Error("Las contraseñas no coinciden.");
    }

    // // . Sign Up User
    const { data: authData, error: authError } = await supabase.auth.signUp({
      email,
      password,
      options: {
        data: {
          first_name: firstName,
          last_name: lastName,
          role: "user", // Default role
        },
      },
    });

    if (authError) {
      throw new Error(authError.message);
    }

    if (!authData.user) {
      throw new Error("No se pudo crear el usuario.");
    }

    // 2. Upload Avatar
    // const fileExt = avatarFile.name.split(".").pop();
    const userId = authData.user.id;
    // const filePath = `${userId}/avatar.${fileExt}`;

    // const { error: uploadError } = await supabase.storage
    //   .from("avatars")
    //   .upload(filePath, avatarFile, {
    //     upsert: true,
    //   });

    // if (uploadError) {
    //   throw new Error(`Error subiendo imagen: ${uploadError.message}`);
    // }

    // const { data: publicURLData } = supabase.storage
    //   .from("avatars")
    //   .getPublicUrl(filePath);

    // const avatarUrl = publicURLData.publicUrl;

    // 3. Insert Profile
    // @ts-ignore
    const { error: profileError } = await supabase.from("profiles").insert({
      id: userId,
      first_name: firstName,
      last_name: lastName,
      student_code: studentCode,
      phone,
      carnet_number: carnetNumber,
      // avatar_url: avatarUrl,
      role: "user",
    });

    if (profileError) {
      // Cleanup auth user if profile creation fails? Ideally yes, but for now just report error.
      throw new Error(`Error creando perfil: ${profileError.message}`);
    }

    successMessage =
      "Registro exitoso. Por favor revisa tu correo para verificar tu cuenta.";
  } catch (error) {
    if (error instanceof Error) {
      errorMessage = error.message;
    } else {
      errorMessage = "Ocurrió un error desconocido.";
    }
  }
}
---

<Layout title="Registro - Megaloblastos">
  <div class="flex items-start justify-center min-h-screen p-4 py-16">
    <div
      class="w-full max-w-2xl bg-white dark:bg-neutral-900 rounded-lg shadow-xl overflow-hidden border border-neutral-200 dark:border-neutral-700"
    >
      <div class="p-8">
        <h2
          class="text-3xl font-bold text-center text-neutral-800 dark:text-neutral-100 mb-8"
        >
          Crear cuenta
        </h2>

        {
          errorMessage && (
            <div class="mb-6 p-4 bg-red-100 border-l-4 border-red-500 text-red-700">
              <p>{errorMessage}</p>
            </div>
          )
        }

        {
          successMessage && (
            <div class="mb-6 p-4 bg-green-100 border-l-4 border-green-500 text-green-700">
              <p>{successMessage}</p>
              <p class="mt-2 text-sm">
                <a href="/auth/login" class="underline font-bold">
                  Ir al inicio de sesión
                </a>
              </p>
            </div>
          )
        }

        <form
          method="POST"
          enctype="multipart/form-data"
          class="space-y-6"
          id="registerForm"
        >
          <!-- Foto de Perfil -->
          <!-- <div>
            <label
              class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2"
              >Foto de Perfil (Real)</label
            >
            <input
              type="file"
              name="avatar"
              accept="image/*"
              required
              class="block w-full text-sm text-neutral-500 dark:text-neutral-400
                file:mr-4 file:py-2 file:px-4
                file:rounded-full file:border-0
                file:text-sm file:font-semibold
                file:bg-amber-600 file:text-white
                hover:file:bg-amber-700"
            />
          </div> -->

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Nombres -->
            <div>
              <label
                class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1"
                >Nombres</label
              >
              <input
                type="text"
                name="firstName"
                required
                class="w-full px-4 py-2 rounded-lg border border-neutral-300 dark:border-neutral-600 bg-neutral-50 dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:ring-2 focus:ring-amber-500 outline-none transition"
              />
            </div>
            <!-- Apellidos -->
            <div>
              <label
                class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1"
                >Apellidos</label
              >
              <input
                type="text"
                name="lastName"
                required
                class="w-full px-4 py-2 rounded-lg border border-neutral-300 dark:border-neutral-600 bg-neutral-50 dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:ring-2 focus:ring-amber-500 outline-none transition"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Código de estudiante -->
            <div>
              <label
                class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1"
                >Código de Estudiante</label
              >
              <input
                type="text"
                name="studentCode"
                required
                class="w-full px-4 py-2 rounded-lg border border-neutral-300 dark:border-neutral-600 bg-neutral-50 dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:ring-2 focus:ring-amber-500 outline-none transition"
              />
            </div>
            <!-- Celular -->
            <div>
              <label
                class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1"
                >Número de Celular</label
              >
              <input
                type="tel"
                name="phone"
                required
                class="w-full px-4 py-2 rounded-lg border border-neutral-300 dark:border-neutral-600 bg-neutral-50 dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:ring-2 focus:ring-amber-500 outline-none transition"
              />
            </div>
          </div>

          <div>
            <!-- Carnet -->
            <label
              class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1"
              >Número de Carnet</label
            >
            <input
              type="text"
              name="carnetNumber"
              required
              class="w-full px-4 py-2 rounded-lg border border-neutral-300 dark:border-neutral-600 bg-neutral-50 dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:ring-2 focus:ring-amber-500 outline-none transition"
            />
          </div>

          <!-- Email -->
          <div>
            <label
              class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1"
              >Correo Electrónico</label
            >
            <input
              type="email"
              name="email"
              required
              class="w-full px-4 py-2 rounded-lg border border-neutral-300 dark:border-neutral-600 bg-neutral-50 dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:ring-2 focus:ring-amber-500 outline-none transition"
            />
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Password -->
            <div>
              <label
                class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1"
                >Contraseña</label
              >
              <input
                type="password"
                name="password"
                required
                minlength="6"
                class="w-full px-4 py-2 rounded-lg border border-neutral-300 dark:border-neutral-600 bg-neutral-50 dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:ring-2 focus:ring-amber-500 outline-none transition"
              />
            </div>
            <!-- Confirm Password -->
            <div>
              <label
                class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1"
                >Repetir Contraseña</label
              >
              <input
                type="password"
                name="confirmPassword"
                required
                minlength="6"
                class="w-full px-4 py-2 rounded-lg border border-neutral-300 dark:border-neutral-600 bg-neutral-50 dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:ring-2 focus:ring-amber-500 outline-none transition"
              />
            </div>
          </div>

          <button
            id="registerBtn"
            type="submit"
            class="w-full py-3 px-4 bg-amber-600 hover:bg-amber-700 text-white font-bold rounded-lg shadow-lg transform transition hover:scale-[1.02] focus:ring-2 focus:ring-offset-2 focus:ring-amber-500 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Registrarse
          </button>
        </form>

        <script>
          const form = document.getElementById(
            "registerForm",
          ) as HTMLFormElement;
          const btn = document.getElementById(
            "registerBtn",
          ) as HTMLButtonElement;

          if (form && btn) {
            form.addEventListener("submit", () => {
              if (form.checkValidity()) {
                btn.disabled = true;
                btn.textContent = "Cargando...";
              }
            });
          }
        </script>

        <p class="mt-6 text-center text-neutral-600 dark:text-neutral-400">
          ¿Ya tienes cuenta?
          <a
            href="/auth/login"
            class="text-amber-600 hover:text-amber-500 font-semibold"
            >Inicia Sesión</a
          >
        </p>
      </div>
    </div>
  </div>
</Layout>
