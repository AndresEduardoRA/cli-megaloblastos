---
import "remixicon/fonts/remixicon.css";
import { Image } from "astro:assets";
// import { supabase } from "../utils/supabase";
import megaloblastosPng from "../assets/megaloblastos.png";

const currentPath = Astro.url.pathname;
const user = Astro.locals.user;

// Verify Admin Role (redundant with middleware but safe)
// Middleware should have already redirected if not admin, but we can double check or just show layout.
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Admin Panel - Megaloblastos</title>
    <!-- Dark mode script -->
    <script is:inline>
      (() => {
        const savedTheme = localStorage.getItem("theme");
        if (savedTheme === "dark") {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body
    class="bg-gray-100 dark:bg-neutral-900 text-neutral-800 dark:text-neutral-200"
  >
    <div class="flex h-screen bg-gray-100 dark:bg-neutral-900 overflow-hidden">
      <!-- Sidebar -->
      <!-- Added mobile classes for toggling -->
      <aside
        id="sidebar"
        class="w-64 bg-white dark:bg-neutral-800 shadow-xl fixed inset-y-0 left-0 z-30 transform -translate-x-full md:translate-x-0 md:relative md:flex flex-col transition-transform duration-300 ease-in-out"
      >
        <header
          class="py-[13px] px-6 border-b border-b-neutral-500 flex justify-between items-center"
        >
          <a href="/" class="flex gap-2 justify-start items-center">
            <Image
              class="w-10 h-10 rounded-full object-cover"
              src={megaloblastosPng}
              alt="Icono megaloblastos"
              width={300}
              height={300}
              loading="lazy"
            />
            <h2
              aria-label="text-sidebar"
              class="text-lg font-medium uppercase text-neutral-800 dark:text-neutral-50"
            >
              Megaloblastos
            </h2>
          </a>
          <!-- Close button for mobile -->
          <button
            id="close-sidebar"
            class="md:hidden text-2xl text-neutral-500"
          >
            <i class="ri-close-line"></i>
          </button>
        </header>

        <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
          <a
            href="/admin/materiales"
            class={`flex items-center gap-3 px-4 py-3 rounded-lg transition ${currentPath.includes("/admin/materiales") ? "bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-500" : "hover:bg-gray-50 dark:hover:bg-neutral-700"}`}
          >
            <i class="ri-book-2-fill text-xl"></i>
            Materiales
          </a>
          <a
            href="/admin/alquiler-de-batas"
            class={`flex items-center gap-3 px-4 py-3 rounded-lg transition ${currentPath.includes("/admin/alquiler-de-batas") ? "bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-500" : "hover:bg-gray-50 dark:hover:bg-neutral-700"}`}
          >
            <i class="ri-t-shirt-2-fill text-xl"></i>
            Alquiler Batas
          </a>
          <a
            href="/admin/sala-de-estudio"
            class={`flex items-center gap-3 px-4 py-3 rounded-lg transition ${currentPath.includes("/admin/sala-de-estudio") ? "bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-500" : "hover:bg-gray-50 dark:hover:bg-neutral-700"}`}
          >
            <i class="ri-calendar-event-fill text-xl"></i>
            Sala Estudio
          </a>
          <a
            href="/admin/usuarios"
            class={`flex items-center gap-3 px-4 py-3 rounded-lg transition ${currentPath.includes("/admin/usuarios") ? "bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-500" : "hover:bg-gray-50 dark:hover:bg-neutral-700"}`}
          >
            <i class="ri-group-fill text-xl"></i>
            Gestionar Usuarios
          </a>
        </nav>

        <div class="p-4 border-t border-neutral-200 dark:border-neutral-700">
          <div class="flex items-center gap-3 px-4 py-3">
            <div
              class="w-8 h-8 rounded-full bg-amber-500 flex items-center justify-center text-white font-bold"
            >
              {user?.email?.charAt(0).toUpperCase()}
            </div>
            <div class="overflow-hidden">
              <p class="text-sm font-semibold truncate">
                {user?.email}
              </p>
              <p class="text-xs text-neutral-500">
                {
                  user?.role === "super_admin"
                    ? "Super Administrador"
                    : "Administrador"
                }
              </p>
            </div>
          </div>
          <button
            id="logout-btn"
            class="w-full mt-2 flex items-center justify-center gap-2 px-4 py-2 text-sm text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition"
          >
            <i class="ri-logout-box-line"></i> Cerrar Sesión
          </button>
        </div>
      </aside>

      <!-- Overlay for mobile -->
      <div
        id="sidebar-overlay"
        class="fixed inset-0 bg-black/50 z-20 hidden md:hidden glass transition-opacity"
        aria-hidden="true"
      >
      </div>

      <!-- Main Content -->
      <div class="flex-1 flex flex-col h-full overflow-hidden relative">
        <!-- Mobile Header -->
        <header
          class="md:hidden bg-white dark:bg-neutral-800 shadow p-4 flex justify-between items-center z-10 shrink-0"
        >
          <span class="font-bold text-lg text-neutral-800 dark:text-neutral-100"
            >Admin Panel</span
          >
          <button
            id="mobile-menu-btn"
            class="text-2xl text-neutral-800 dark:text-neutral-100"
          >
            <i class="ri-menu-line"></i>
          </button>
        </header>

        <main class="flex-1 overflow-auto p-6 md:p-12 relative">
          <slot />
        </main>
      </div>
    </div>

    <script>
      import { supabase } from "../utils/supabase";

      const logoutBtn = document.getElementById("logout-btn");
      if (logoutBtn) {
        logoutBtn.addEventListener("click", async () => {
          await supabase.auth.signOut();
          window.location.href = "/auth/login";
        });
      }

      // Sidebar Toggle Logic
      const sidebar = document.getElementById("sidebar");
      const overlay = document.getElementById("sidebar-overlay");
      const menuBtn = document.getElementById("mobile-menu-btn");
      const closeBtn = document.getElementById("close-sidebar");

      function openSidebar() {
        sidebar?.classList.remove("-translate-x-full");
        overlay?.classList.remove("hidden");
      }

      function closeSidebar() {
        sidebar?.classList.add("-translate-x-full");
        overlay?.classList.add("hidden");
      }

      menuBtn?.addEventListener("click", openSidebar);
      closeBtn?.addEventListener("click", closeSidebar);
      overlay?.addEventListener("click", closeSidebar);
    </script>
  </body>
</html>
